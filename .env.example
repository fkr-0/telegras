# Example .env file for telegras
# Copy this file to .env and customize as needed

# How telegras receives Telegram updates
# Options: webhook, polling
BOT_MODE=webhook

# Settings for polling mode (only used when BOT_MODE=polling)
BOT_POLLING_TIMEOUT_SECONDS=30
BOT_POLLING_ERROR_BACKOFF_SECONDS=2.0
BOT_POLLING_IDLE_SLEEP_SECONDS=0.25